    <!-- ── Screen 1: Permissions Onboarding ─────────────────────────────── -->
    <string name="screen_setup_title">Setup &amp; Permissions</string>
    <string name="screen_setup_subtitle">Grant these permissions once to enable full automation</string>
    <string name="all_permissions_granted">All permissions granted! You\'re ready to go.</string>
    <string name="permissions_incomplete">Please grant all permissions to start automation.</string>

    <!-- Permission: Accessibility -->
    <string name="perm_accessibility_title">Accessibility Service</string>
    <string name="perm_accessibility_subtitle">स्क्रीन से किराया और दूरी पढ़ने के लिए (To read fare &amp; distance from screen)</string>
    <string name="perm_accessibility_why">Ride Auto-Acceptor needs Accessibility permission to read the fare amount (e.g., ₹89) and distances (e.g., 1.6 km) shown on ride request popups — and to tap the Accept button on your behalf.\n\nआपकी screen पर दिखाई देने वाले ride request popup से fare और distance पढ़ने के लिए यह permission जरूरी है।</string>
    <string name="perm_accessibility_action">Enable Accessibility</string>

    <!-- Permission: Notification Listener -->
    <string name="perm_notification_title">Notification Access</string>
    <string name="perm_notification_subtitle">Ride requests को notification से detect करने के लिए</string>
    <string name="perm_notification_why">Notification Access allows the app to detect ride requests the moment they arrive — even if you\'re on a different screen.\n\nजब भी कोई ride request आए, तुरंत detect हो सके — इसके लिए notification access जरूरी है।</string>
    <string name="perm_notification_action">Enable Notification Access</string>

    <!-- Permission: Display Over Apps -->
    <string name="perm_overlay_title">Display Over Other Apps</string>
    <string name="perm_overlay_subtitle">दूसरे apps के ऊपर status दिखाने के लिए</string>
    <string name="perm_overlay_why">This permission lets Ride Auto-Acceptor show a small status indicator while you\'re using other apps (like navigation).\n\nजब आप दूसरे apps use कर रहे हों, तब भी automation status दिखाने के लिए यह permission चाहिए।</string>
    <string name="perm_overlay_action">Enable Display Over Apps</string>

    <!-- Permission: Battery Optimization -->
    <string name="perm_battery_title">Ignore Battery Optimization</string>
    <string name="perm_battery_subtitle">Background में बिना रुके चलते रहने के लिए</string>
    <string name="perm_battery_why">Without this, Android may pause the app in the background, causing you to miss ride requests.\n\nBattery optimization से app background में रुक सकती है और ride requests miss हो सकती हैं। इसे disable करना जरूरी है।</string>
    <string name="perm_battery_action">Disable Battery Optimization</string>

