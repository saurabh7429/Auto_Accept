    <string name="app_tagline">Smart Automation for Ride-Hailing Drivers</string>
    <string name="accessibility_service_label">Ride Auto-Acceptor</string>
    <string name="accessibility_service_description">Reads fare and distance from ride request popups and automatically clicks Accept when your criteria are met.</string>
    <string name="notification_service_label">Ride Notification Listener</string>

