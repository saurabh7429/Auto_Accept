<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_md">

            <!-- Header -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/screen_settings_title"
                android:textSize="26sp"
                android:textColor="@color/color_on_surface"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="-0.02"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_subtitle"
                android:textSize="13sp"
                android:textColor="@color/color_on_surface_variant"
                android:lineSpacingMultiplier="1.4"
                android:layout_marginBottom="20dp" />

            <!-- ── Section: Apps ───────────────────────────────────────────── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/section_apps"
                android:textSize="12sp"
                android:textColor="@color/color_primary"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="10dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardBackgroundColor="@color/color_surface"
                app:cardCornerRadius="16dp"
                app:strokeColor="@color/color_card_stroke"
                app:strokeWidth="1dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp">

                    <!-- Ola -->
                    <LinearLayout android:id="@+id/row_ola"
                        android:layout_width="match_parent" android:layout_height="56dp"
                        android:orientation="horizontal" android:gravity="center_vertical">
                        <TextView android:id="@+id/tv_icon_ola" android:layout_width="36dp" android:layout_height="36dp" android:gravity="center" android:textSize="20sp" android:layout_marginEnd="12dp" android:text="🟢"/>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <TextView android:id="@+id/tv_name_ola" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="15sp" android:textColor="@color/color_on_surface" android:fontFamily="sans-serif-medium" android:text="@string/app_ola"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="11sp" android:textColor="@color/color_text_hint" android:text="com.olacabs.oladriver"/>
                        </LinearLayout>
                        <com.google.android.material.switchmaterial.SwitchMaterial android:id="@+id/switch_ola" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    </LinearLayout>
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/color_divider"/>

                    <!-- Rapido -->
                    <LinearLayout android:id="@+id/row_rapido"
                        android:layout_width="match_parent" android:layout_height="56dp"
                        android:orientation="horizontal" android:gravity="center_vertical">
                        <TextView android:id="@+id/tv_icon_rapido" android:layout_width="36dp" android:layout_height="36dp" android:gravity="center" android:textSize="20sp" android:layout_marginEnd="12dp" android:text="⚡"/>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <TextView android:id="@+id/tv_name_rapido" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="15sp" android:textColor="@color/color_on_surface" android:fontFamily="sans-serif-medium" android:text="@string/app_rapido"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="11sp" android:textColor="@color/color_text_hint" android:text="com.rapido.captain"/>
                        </LinearLayout>
                        <com.google.android.material.switchmaterial.SwitchMaterial android:id="@+id/switch_rapido" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    </LinearLayout>
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/color_divider"/>

                    <!-- Uber -->
                    <LinearLayout android:id="@+id/row_uber"
                        android:layout_width="match_parent" android:layout_height="56dp"
                        android:orientation="horizontal" android:gravity="center_vertical">
                        <TextView android:id="@+id/tv_icon_uber" android:layout_width="36dp" android:layout_height="36dp" android:gravity="center" android:textSize="20sp" android:layout_marginEnd="12dp" android:text="🚗"/>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <TextView android:id="@+id/tv_name_uber" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="15sp" android:textColor="@color/color_on_surface" android:fontFamily="sans-serif-medium" android:text="@string/app_uber"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="11sp" android:textColor="@color/color_text_hint" android:text="com.ubercab.driver"/>
                        </LinearLayout>
                        <com.google.android.material.switchmaterial.SwitchMaterial android:id="@+id/switch_uber" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    </LinearLayout>
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/color_divider"/>

                    <!-- Porter -->
                    <LinearLayout android:id="@+id/row_porter"
                        android:layout_width="match_parent" android:layout_height="56dp"
                        android:orientation="horizontal" android:gravity="center_vertical">
                        <TextView android:id="@+id/tv_icon_porter" android:layout_width="36dp" android:layout_height="36dp" android:gravity="center" android:textSize="20sp" android:layout_marginEnd="12dp" android:text="📦"/>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <TextView android:id="@+id/tv_name_porter" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="15sp" android:textColor="@color/color_on_surface" android:fontFamily="sans-serif-medium" android:text="@string/app_porter"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="11sp" android:textColor="@color/color_text_hint" android:text="com.porter.partner"/>
                        </LinearLayout>
                        <com.google.android.material.switchmaterial.SwitchMaterial android:id="@+id/switch_porter" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    </LinearLayout>
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/color_divider"/>

                    <!-- InDrive (Phase 2) -->
                    <LinearLayout android:id="@+id/row_indrive"
                        android:layout_width="match_parent" android:layout_height="56dp"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:alpha="0.4">
                        <TextView android:id="@+id/tv_icon_indrive" android:layout_width="36dp" android:layout_height="36dp" android:gravity="center" android:textSize="20sp" android:layout_marginEnd="12dp" android:text="🚕"/>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <TextView android:id="@+id/tv_name_indrive" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="15sp" android:textColor="@color/color_on_surface" android:fontFamily="sans-serif-medium" android:text="@string/app_indrive"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="11sp" android:textColor="@color/color_text_hint" android:text="com.sap.indrive.driver"/>
                        </LinearLayout>
                        <com.google.android.material.switchmaterial.SwitchMaterial android:id="@+id/switch_indrive" android:layout_width="wrap_content" android:layout_height="wrap_content" android:enabled="false"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── Section: Ride Criteria ──────────────────────────────────── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/section_filters"
                android:textSize="12sp"
                android:textColor="@color/color_primary"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="10dp" />

            <!-- Max Pickup Distance -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/color_surface"
                app:cardCornerRadius="16dp"
                app:strokeColor="@color/color_card_stroke"
                app:strokeWidth="1dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="4dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/filter_max_pickup"
                                android:textSize="15sp"
                                android:textColor="@color/color_on_surface"
                                android:fontFamily="sans-serif-medium" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/filter_max_pickup_desc"
                                android:textSize="12sp"
                                android:textColor="@color/color_on_surface_variant"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switch_max_pickup"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/container_max_pickup"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="12dp"
                        android:visibility="gone">

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.RideAutoAcceptor.TextInput"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:hint="@string/filter_max_pickup_hint">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/et_max_pickup_km"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="numberDecimal"
                                android:imeOptions="actionDone"
                                android:textColor="@color/color_on_surface" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="km"
                            android:textSize="14sp"
                            android:textColor="@color/color_on_surface_variant"
                            android:layout_marginStart="8dp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Min Drop Distance -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/color_surface"
                app:cardCornerRadius="16dp"
                app:strokeColor="@color/color_card_stroke"
                app:strokeWidth="1dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="4dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/filter_min_drop"
                                android:textSize="15sp"
                                android:textColor="@color/color_on_surface"
                                android:fontFamily="sans-serif-medium" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/filter_min_drop_desc"
                                android:textSize="12sp"
                                android:textColor="@color/color_on_surface_variant"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switch_min_drop"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/container_min_drop"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="12dp"
                        android:visibility="gone">

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.RideAutoAcceptor.TextInput"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:hint="@string/filter_min_drop_hint">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/et_min_drop_km"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="numberDecimal"
                                android:imeOptions="actionDone"
                                android:textColor="@color/color_on_surface" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="km"
                            android:textSize="14sp"
                            android:textColor="@color/color_on_surface_variant"
                            android:layout_marginStart="8dp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Min Fare -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="@color/color_surface"
                app:cardCornerRadius="16dp"
                app:strokeColor="@color/color_card_stroke"
                app:strokeWidth="1dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="4dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/filter_min_fare"
                                android:textSize="15sp"
                                android:textColor="@color/color_on_surface"
                                android:fontFamily="sans-serif-medium" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/filter_min_fare_desc"
                                android:textSize="12sp"
                                android:textColor="@color/color_on_surface_variant"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switch_min_fare"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/container_min_fare"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="12dp"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="₹"
                            android:textSize="20sp"
                            android:textColor="@color/color_secondary"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginEnd="8dp" />

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.RideAutoAcceptor.TextInput"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:hint="@string/filter_min_fare_hint">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/et_min_fare"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="numberDecimal"
                                android:imeOptions="actionDone"
                                android:textColor="@color/color_on_surface" />
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
