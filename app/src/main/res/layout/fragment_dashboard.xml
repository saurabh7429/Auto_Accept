<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_md">

            <!-- ── Hero Toggle Card ─────────────────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_toggle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/color_surface"
                app:cardCornerRadius="24dp"
                app:strokeColor="@color/color_card_stroke"
                app:strokeWidth="1dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="28dp"
                    android:gravity="center">

                    <!-- Large ON/OFF label -->
                    <TextView
                        android:id="@+id/tv_automation_state"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/automation_disabled"
                        android:textSize="22sp"
                        android:textColor="@color/color_on_surface"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="20dp"
                        android:letterSpacing="-0.01" />

                    <!-- Giant toggle switch -->
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_master"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:scaleX="1.8"
                        android:scaleY="1.8"
                        android:layout_marginBottom="20dp"
                        app:thumbTint="@color/color_on_primary"
                        app:trackTint="@color/color_toggle_off"
                        app:trackTintMode="src_in" />

                    <!-- Toggle hint -->
                    <TextView
                        android:id="@+id/tv_toggle_hint"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/toggle_hint_enable"
                        android:textSize="13sp"
                        android:textColor="@color/color_on_surface_variant" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── Service Status Card ──────────────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_service_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/color_surface"
                app:cardCornerRadius="16dp"
                app:strokeColor="@color/color_card_stroke"
                app:strokeWidth="1dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Service Status"
                        android:textSize="12sp"
                        android:textColor="@color/color_on_surface_variant"
                        android:textAllCaps="true"
                        android:letterSpacing="0.08"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/tv_service_status"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/service_status_inactive"
                        android:textSize="15sp"
                        android:textColor="@color/color_on_surface"
                        android:lineSpacingMultiplier="1.3" />

                    <!-- Last event info -->
                    <TextView
                        android:id="@+id/tv_last_event"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/no_events_yet"
                        android:textSize="13sp"
                        android:textColor="@color/color_on_surface_variant"
                        android:layout_marginTop="8dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── Stats Row ───────────────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <!-- Accepted today -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:cardBackgroundColor="@color/color_surface"
                    app:cardCornerRadius="16dp"
                    app:strokeColor="@color/color_primary"
                    app:strokeWidth="1dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tv_accepted_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="40sp"
                            android:textColor="@color/color_accepted"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/stat_today_accepted"
                            android:textSize="12sp"
                            android:textColor="@color/color_on_surface_variant"
                            android:gravity="center"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Skipped today -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    app:cardBackgroundColor="@color/color_surface"
                    app:cardCornerRadius="16dp"
                    app:strokeColor="@color/color_skipped_text"
                    app:strokeWidth="1dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tv_skipped_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="40sp"
                            android:textColor="@color/color_skipped_text"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/stat_today_skipped"
                            android:textSize="12sp"
                            android:textColor="@color/color_on_surface_variant"
                            android:gravity="center"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- ── Accessibility Warning (shown when not enabled) ──────────── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_accessibility_warning"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:visibility="gone"
                app:cardBackgroundColor="@color/color_error_container"
                app:cardCornerRadius="12dp"
                app:strokeColor="@color/color_error"
                app:strokeWidth="1dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="⚠️  Accessibility Service not enabled. Go to Setup tab."
                        android:textSize="13sp"
                        android:textColor="@color/color_error"
                        android:lineSpacingMultiplier="1.3" />

                    <Button
                        android:id="@+id/btn_fix_accessibility"
                        style="@style/Widget.RideAutoAcceptor.Button.Primary"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="Fix"
                        android:textSize="12sp"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
